  "defaultLogisticsServices": {
    "arrival": {
      "code": "TRANSFER_IN",
      "title": "Recojo desde aeropuerto o terminal terrestre",
      "description": "Servicio incluido al inicio del paquete, coordinado según la hora real de llegada del pasajero.",
      "dayPosition": "first_day",
      "required": true,
      "includedByDefault": true,
      "renderAs": "logistics-service"
    },
    "departure": {
      "code": "TRANSFER_OUT",
      "title": "Traslado al aeropuerto o terminal terrestre",
      "description": "Servicio incluido al finalizar el paquete, coordinado según la hora real de salida del pasajero.",
      "dayPosition": "last_day",
      "required": true,
      "includedByDefault": true,
      "renderAs": "logistics-service"
    }
  },
  "globalRules": {
    "doNotHardcodeItineraries": true,
    "generateCombinationsDynamically": true,
    "deduplicateByContent": true,
    "deduplicateIgnoresOrder": true,
    "sortItineraryAfterGeneration": true,
    "respectArrivalDepartureProfiles": true,
    "respectTourOperationalSchedule": true,
    "firstDayBufferHoursAfterArrival": 1.5,
    "lastDayBufferHoursBeforeDeparture": 2,
    "minimumRestHoursBeforeTrekkings": 8,
    "maximumOneMachuPicchuExperiencePerPackage": true,
    "valleVipIncludesMaras": true,
    "doNotDuplicateMarasWhenVipValleyIsSelected": true,
    "sacredValleyConnectionRequiresOvernightMachuPicchu": true,
    "trekkingAfterMachuPicchuRequiresOvernightExpress": true,
    "threeDaysTwoNightsRequiresFullDayMachuPicchu": true,
    "trainRules": {
      "sourceOfTruth": "assets/data/trains.json",
      "sameCompanyRoundTripDefault": true,
      "allowMixedCompaniesDefault": false,
      "doNotMixPeruRailAndIncaRail": true,
      "fixedTrainVersionsMustNotExposeTrainSelector": true,
      "flexibleTrainVersionsFilterReturnByOutboundCompany": true
    }
  },
  "generationEngine": {
    "combinationStrategy": "choose_required_then_optional_until_service_days_are_filled",
    "availableServiceDaysFormula": "days - arrivalBufferDayImpact - departureBufferDayImpact",
    "contentSignatureFields": [
      "includedTourCodes",
      "machuPicchuMode",
      "connectionMode",
      "trekkingCodes",
      "vipMode"
    ],
    "dedupeSignatureStrategy": "sort_codes_and_flags_before_hash",
    "orderingStrategy": [
      "arrival_or_welcome_first",
      "soft_cultural_before_high_altitude",
      "city_tour_before_full_day_trekking_when_possible",
      "sacred_valley_before_machu_picchu_when_connection",
      "machu_picchu_full_day_or_overnight_by_rule",
      "avoid_trekking_immediately_after_late_return_except_overnight_express",
      "last_day_only_short_or_transfer_compatible"
    ],
    "rankingStrategy": [
      "profile_compatibility",
      "required_tours_satisfied",
      "operational_feasibility",
      "sales_value",
      "variety_of_experiences",
      "lower_duplicate_similarity"
    ],
    "maxGeneratedOptionsPerDuration": 36,
    "maxRenderedOptionsPerPage": 12
  },
