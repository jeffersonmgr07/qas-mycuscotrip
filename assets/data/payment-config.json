    "manual_payment": {
      "enabled": true,
      "label": "Pago manual coordinado",
      "type": "manual",
      "integrationStatus": "available_as_fallback",
      "environment": "manual",
      "mode": "manual_confirmation",
      "supportedCurrencies": [
        "USD",
        "EUR",
        "GBP",
        "JPY",
        "MXN",
        "PEN",
        "ARS",
        "BRL",
        "CLP",
        "COP"
