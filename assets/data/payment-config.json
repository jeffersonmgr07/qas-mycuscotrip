  "paymentModes": {
    "full": {
      "code": "full",
      "label": "Pago completo",
      "description": "El cliente paga el total del producto o paquete al momento de reservar.",
      "enabled": true,
      "discountEligible": true,
      "defaultDiscountPercent": 0
    },
    "partial": {
      "code": "partial",
      "label": "Separar cupo",
      "description": "El cliente paga un anticipo por persona y completa el saldo antes del viaje o según coordinación.",
      "enabled": true,
      "discountEligible": false,
      "defaultPartialPaymentPerPerson": {
        "USD": 50,
        "EUR": 50,
        "GBP": 45,
        "JPY": 7500,
        "MXN": 900,
        "PEN": 180,
        "ARS": 50000,
        "BRL": 250,
        "CLP": 45000,
        "COP": 200000
      }
    }
  },
  "productRules": {
    "tour": {
      "allowedPaymentModes": [
        "full",
        "partial"
      ],
      "preferredProviderResolution": "currency_first"
    },
    "package": {
      "allowedPaymentModes": [
        "full",
        "partial"
      ],
      "preferredProviderResolution": "currency_first",
      "allowHiddenServiceFee": true,
      "allowInternalProfitAnalytics": true
    },
    "custom_quote": {
      "allowedPaymentModes": [
        "full",
        "partial"
      ],
      "preferredProviderResolution": "manual_first",
      "allowManualAdjustment": true
    }
  },
  "currencyProviderMap": {
    "USD": "paypal",
    "EUR": "paypal",
    "GBP": "paypal",
    "JPY": "paypal",
    "MXN": "paypal",
    "PEN": "mercado_pago",
    "ARS": "mercado_pago",
    "BRL": "mercado_pago",
    "CLP": "mercado_pago",
    "COP": "mercado_pago"
  },
  "checkoutFlow": {
    "staticFrontendCompatibility": {
      "githubPages": true,
      "notes": "GitHub Pages puede mostrar botones y redirigir, pero no debe crear órdenes definitivas ni preferencias con tokens privados directamente desde frontend."
    },
    "recommendedNextPhase": {
      "paypal": "Implementar PayPal JS SDK con validación de monto y moneda. Para mayor seguridad, crear orden desde backend o serverless.",
      "mercado_pago": "Implementar creación de preferencia mediante backend o serverless y renderizar Checkout Pro o Wallet Brick en frontend."
    },
    "requiredBeforeProduction": [
      "Validar moneda soportada por proveedor.",
      "Validar monto final en servidor o función segura.",
      "Registrar código de reserva.",
      "Guardar estado del pago.",
      "Confirmar pago con webhook o verificación posterior.",
      "No confiar únicamente en el frontend para confirmar reservas pagadas."
    ]
  },
  "privateDashboardPreparation": {
    "enabledForFuture": true,
    "fieldsToTrack": [
      "provider",
      "currency",
      "grossAmount",
      "gatewayFeeEstimated",
      "bankWithdrawalFeeEstimated",
      "netReceivedEstimated",
      "internalCost",
      "targetProfit",
      "actualProfit",
      "maximumDiscountAllowed",
      "paymentStatus",
      "reservationCode"
    ],
    "notes": "Estos campos permitirán que una futura vista privada muestre utilidad, costo real, descuento máximo y estado de pago por cotización o reserva."
  },
  "status": "published"
}
